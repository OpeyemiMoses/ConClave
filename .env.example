# --- Gemini (all agents) ---
GEMINI_API_KEY=AIza...
# gemini-3.1-flash-lite: GA, high-volume workhorse tier — ~1,000+ RPD / 30 RPM
# on free tier. gemini-3.5-flash is a frontier model with only 20 RPD free —
# do not use it for this pipeline unless you're on a paid tier.
GEMINI_MODEL=gemini-3.1-flash-lite

# --- OKX x402 payment (ASP surface) ---
# From https://web3.okx.com/zh-hans/onchainos/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# Your Agentic Wallet address that receives payments
PAY_TO_ADDRESS=0xYourWalletAddress
# eip155:1952 = X Layer Testnet (default, safe to test with faucet funds)
# eip155:196  = X Layer Mainnet (flip once verified end-to-end)
X402_NETWORK=eip155:1952

# --- Paid-flow test script only (npm run test:payment) ---
# A THROWAWAY key, funded only via the X Layer testnet faucet. Never a real
# wallet's key. This account SPENDS money to hit your own paid endpoint —
# it's separate from PAY_TO_ADDRESS above, which RECEIVES it.
TEST_WALLET_PRIVATE_KEY=0x...

PORT=4000
